RewriteEngine On
DirectoryIndex index.php

# Blokir akses file/direktori sensitif yang ikut ter-deploy ke webroot
RewriteRule (^|/)\.(git|env|github|replit)(/|$) - [F,L]
<FilesMatch "(^\.|\.(env|mod|sum|lock|yaml|yml|md|json|ts|go|sh|mjs|php~)$)">
  Require all denied
</FilesMatch>
<Files "index.php">
  Require all granted
</Files>

# Jika file/folder statis ada, serve langsung
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Semua request lain → proxy PHP ke Go backend
RewriteRule ^ index.php [L]
