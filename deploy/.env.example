# Salin ke .env di root repo sebelum menjalankan docker compose:
#   cp deploy/.env.example .env

PORT=3000
TZ=Asia/Jakarta
DATA_DIR=./data
ANGGARAN_FILE=/app/Anggaran.xlsx

# Domain production — wajib diisi saat deploy
ALLOWED_ORIGIN=https://sakubijak.com

# Ganti password default sebelum go-live
SIPKEU_ADMIN_USER=admin
SIPKEU_ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN
SIPKEU_OPERATOR_USER=operator
SIPKEU_OPERATOR_PASSWORD=GANTI_PASSWORD_OPERATOR

SIPKEU_TRUST_PROXY=1
SIPKEU_API_RATE_LIMIT=3000
SIPKEU_LOGIN_RATE_LIMIT=180
SIPKEU_IP_RATE_LIMIT=1500
SIPKEU_ASSET_RATE_LIMIT=4000
SIPKEU_PORTAL_STATUS_RATE=360
SIPKEU_MAX_CONN_PER_IP=72
SIPKEU_GLOBAL_MAX_CONN=22000
SIPKEU_MAX_SESSIONS=25000

# ── Backup harian ke OneDrive (salin ke deploy/.env, tidak di-commit) ──
# SSH_PASSWORD=password-ssh-hostinger-anda
